rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Task image attachments: images/{uid}/{taskId}/{filename}
    match /images/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // V19: 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }
    // V19 — non-image file attachments (PDF etc.): files/{uid}/{taskId}/{filename}
    match /files/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && (request.resource.contentType == 'application/pdf');
    }
    // V26 — Hlášení ze stavby. Foto + video. 50MB limit pro video,
    //   10MB pro image (per existing image limit).
    match /reports/{uid}/{reportId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (
                     // Image: 10MB max
                     (request.resource.contentType.matches('image/.*')
                      && request.resource.size < 10 * 1024 * 1024)
                     // Video: 50MB max
                     || (request.resource.contentType.matches('video/.*')
                         && request.resource.size < 50 * 1024 * 1024)
                   );
    }

    // ============================================================
    //  V27 — Rozpočet domu (in-app mode "Rozpočet")
    //
    //  PDF přílohy faktur. Path: /budget_invoices/{invoiceId}.
    //
    //  Strategy: jen signed-in user (= konzistentní s pattern existujícího
    //  /files/{uid}/{taskId}/{filename}). OWNER-only enforcement běží
    //  v Firestore rules (`/budget_sections/**` jsou OWNER-only, takže
    //  PM ani nemůže získat platný invoiceId pro Storage path).
    //
    //  Limit: 10 MB, jen application/pdf.
    //  Nepoužíváme firestore.get() cross-service lookup — má edge cases
    //  napříč Firebase projekty a pro 2-OWNER family app je obscurity stačí.
    // ============================================================
    match /budget_invoices/{invoiceId} {
      allow read, delete: if request.auth != null;
      allow write:
        if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
