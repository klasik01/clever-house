rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Task image attachments: images/{uid}/{taskId}/{filename}
    match /images/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // V19: 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }
    // V19 — non-image file attachments (PDF etc.): files/{uid}/{taskId}/{filename}
    match /files/{uid}/{taskId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && (request.resource.contentType == 'application/pdf');
    }
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
