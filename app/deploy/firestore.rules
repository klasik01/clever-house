rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------ Helpers ------
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner() {
      return isSignedIn() && userRole() == 'OWNER';
    }

    function isProjectManager() {
      return isSignedIn() && userRole() == 'PROJECT_MANAGER';
    }

    // V24 — Stavbyvedoucí (externí dodavatel ze stejné firmy jako PM).
    function isConstructionManager() {
      return isSignedIn() && userRole() == 'CONSTRUCTION_MANAGER';
    }

    // V5 — batch comment writes touch the parent task to bump commentCount / updatedAt
    // (and optionally status + assigneeUid when the comment carries a workflow action).
    // Any signed-in user must be able to make this side-effect update, otherwise e.g. PM
    // commenting on an OWNER-created task fails the whole batch. We gate by requiring
    // commentCount to be one of the affected keys — prevents this clause from being
    // abused to flip status/assignee without actually writing a comment.
    function isCommentSideEffect() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['commentCount', 'updatedAt', 'status', 'assigneeUid'])
             && request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['commentCount']);
    }

    // Task creator (V3 multi-author ready). Also covers legacy OWNER-created tasks.
    function isTaskAuthor() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // V17.1 — cross-OWNER edit: OWNER účet je sdílený prostor (typicky
    //   manžel + manželka). Co vytvořil jeden OWNER, může druhý editovat.
    //   PM-created tasky jsou soukromé (jen autor-PM).
    //
    //   Legacy tasky bez authorRole default na OWNER (historicky v drtivé
    //   většině, PM teprve nedávno dostal schopnost create).
    function isCrossOwnerEditable() {
      return isOwner() && (
        !('authorRole' in resource.data)
        || resource.data.authorRole == 'OWNER'
      );
    }

    // V24 — cross-CM edit: dva CM ze stejné firmy = tým, vzájemně se editují
    //   (analog cross-OWNER). Žádný legacy fallback — každý CM-vytvořený task
    //   má authorRole snapshot, protože CM rola vznikla až ve V24.
    function isCrossCmEditable() {
      return isConstructionManager()
        && 'authorRole' in resource.data
        && resource.data.authorRole == 'CONSTRUCTION_MANAGER';
    }

    // V24 — read scope helper pro CM. Volá se s task daty (resource.data nebo
    //   get().data). Vrací true jen pokud CM smí číst daný task.
    //
    //   Pravidla:
    //     - napad: NIKDY (rodinný brainstorming OWNER+manželka, NDA hranice)
    //     - otazka/ukol: jen pokud je CM assignee, creator, nebo task patří
    //       do CM teamu (authorRole snapshot CM nebo assignee má CM rolu)
    //     - dokumentace: jen pokud sharedWithRoles obsahuje CM
    //
    //   Note: get() na users/{assigneeUid} je placený read per evaluation.
    //   Pro náš dataset (~100 tasků, ~5 useři) cena akceptovatelná. Pokud
    //   v budoucnu bottleneck → snapshot assigneeRole na task při assignment.
    function canReadTaskByCm(t) {
      return (
        // otazka/ukol: vlastní + cross-CM team
        t.type in ['otazka', 'ukol']
        && (
          t.assigneeUid == request.auth.uid
          || t.createdBy == request.auth.uid
          || (t.get('authorRole', '') == 'CONSTRUCTION_MANAGER')
          || (
            t.get('assigneeUid', null) != null
            && get(/databases/$(database)/documents/users/$(t.assigneeUid)).data.role == 'CONSTRUCTION_MANAGER'
          )
        )
      ) || (
        // dokumentace: jen pokud explicitně sdíleno s CM rolu
        t.type == 'dokumentace'
        && t.get('sharedWithRoles', []) is list
        && 'CONSTRUCTION_MANAGER' in t.get('sharedWithRoles', [])
      );
    }

    // V24 — sjednocený read gate pro tasks. OWNER + PM mají plný přístup,
    //   CM má scoped přístup přes canReadTaskByCm.
    function canReadTask(t) {
      return isOwner() || isProjectManager()
        || (isConstructionManager() && canReadTaskByCm(t));
    }

    // ------ Users ------
    // V3: any authenticated user can list users (for mention autocomplete + assignee dropdown).
    match /users/{uid} {
      allow read: if isSignedIn();

      // V16.1 — user may self-update notificationPrefs a displayName
      // ("Přezdívka"). Role + email zůstávají Admin-SDK only. Diff gate
      // odmítne i balíčkovaný patch, který by se snažil změnit cokoliv
      // jiného. Oba fieldy lze posílat zvlášť nebo společně.
      //
      // V18-S12 — přidány `calendarToken` a `calendarTokenRotatedAt`
      // (webcal subscription) + bookkeeping `updatedAt`. User si sám
      // lazy-generuje token při prvním otevření Kalendář sekce a dělá
      // reset přes stejné diff-gate. Server-side (CF, admin) pořád
      // může psát pomocí Admin SDK bez těchto rules.
      allow update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly([
                         'notificationPrefs',
                         'displayName',
                         'contactEmail',
                         'calendarToken',
                         'calendarTokenRotatedAt',
                         'calendarLastFetchedAt',
                         'onboardingCompletedAt',
                         'updatedAt',
                       ]);

      // Create / delete via Admin SDK only.
      allow create, delete: if false;

      // ------ Devices (FCM registrations, V15) ------
      // Each user owns their own devices subcollection. Nobody else can
      // read or write — tokens are effectively credentials for push
      // delivery, they don't leave the owning account.
      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // ------ Notifications inbox (V15.1) ------
      // Mirror of push notifications, persisted for in-app feed. Server
      // (Cloud Function) writes; owner reads + marks-read. Owner can't
      // delete (keeps a consistent audit trail); retention lives in a
      // scheduled cleanup function.
      match /notifications/{notifId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        // Owner may only patch readAt to set it from null → timestamp.
        // No other field can be modified from the client — content is
        // written server-side.
        allow update: if isSignedIn()
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['readAt']);
        // Create + delete via Admin SDK only (Cloud Function).
        allow create, delete: if false;
      }
    }

    // ------ Tasks ------
    match /tasks/{taskId} {
      // READ — V24:
      //   OWNER + PM: plný přístup (workspace má jednu rodinu + jejich PM/firmu;
      //     historicky neměly task-level secrets, V15.2 zpřístupnilo všem).
      //   CM (Stavbyvedoucí): scoped přes canReadTaskByCm.
      //     - napad: NIKDY (rodinný brainstorming, NDA hranice)
      //     - otazka/ukol: vlastní + cross-CM team scope
      //     - dokumentace: jen pokud sharedWithRoles obsahuje 'CONSTRUCTION_MANAGER'
      //
      //   Deep-linkování z push notifikace nesmí pro CM odkrýt skrytý task —
      //   notifikační pipeline (V24, S08) gate-checne canReadTask před pushem.
      allow read: if canReadTask(resource.data);

      // CREATE — V24 model:
      //   - createdBy musí být self
      //   - sensible type + status
      //   - authorRole snapshot z {OWNER, PROJECT_MANAGER, CONSTRUCTION_MANAGER}
      //   - CM nesmí vytvořit napad ani dokumentaci (per BRIEF scope)
      //   - napad nesmí mít CM jako assignee (defense in depth pro AssigneeSelect)
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.type in ['napad', 'otazka', 'ukol', 'dokumentace']
                    && request.resource.data.status is string
                    && request.resource.data.authorRole in ['OWNER', 'PROJECT_MANAGER', 'CONSTRUCTION_MANAGER']
                    && (
                      // CM smí vytvořit jen otazka/ukol
                      request.resource.data.authorRole != 'CONSTRUCTION_MANAGER'
                      || request.resource.data.type in ['otazka', 'ukol']
                    )
                    && (
                      // napad nesmí mít CM jako assignee
                      request.resource.data.type != 'napad'
                      || !('assigneeUid' in request.resource.data)
                      || request.resource.data.assigneeUid == null
                      || get(/databases/$(database)/documents/users/$(request.resource.data.assigneeUid)).data.role != 'CONSTRUCTION_MANAGER'
                    );

      // UPDATE — V24 model:
      //   - Autor tasku může editovat vše.
      //   - OWNER může editovat jakýkoliv OWNER-vytvořený task (cross-OWNER
      //     shared workspace — manželé sdílí). [V17.1]
      //   - CM může editovat jakýkoliv CM-vytvořený task (cross-CM tým — dvou+
      //     stavbyvedoucích z jedné firmy). [V24]
      //   - Jakýkoliv signed-in s read přístupem může aplikovat comment-side-effect
      //     diff, aby batch writes z createComment prošly bez ohledu na autora tasku.
      //   - PM-vytvořený task smí editovat jen autor-PM (žádná cross-PM
      //     sharing; PM je jednotlivec, ne sdílený účet).
      //
      // V18-S40 — tato rule pokrývá i:
      //   - Změnu pole `type` (otazka ↔ ukol mutace) — UI gating přes
      //     canChangeTaskType (lib/permissions.ts), server-side jen edit
      //     check (žádná schema-level constraint na type).
      //   - Many-to-many link mezi otázkou/úkolem a tématem (nápadem) přes
      //     `linkedTaskIds`. Bidirectional batch update zapisuje na oba
      //     dokumenty; když uživatel nemá edit na jednu stranu, ta část batch
      //     padne a celý write se odroluje.
      //
      // V24 — comment-side-effect path je nově gated na canReadTask, aby CM
      //   nemohl flip-statusovat task, který nemá v read scope.
      allow update: if isTaskAuthor()
                    || isCrossOwnerEditable()
                    || isCrossCmEditable()
                    || (
                      isSignedIn()
                      && isCommentSideEffect()
                      && canReadTask(resource.data)
                    );

      // DELETE — pouze autor. Cross-OWNER ani cross-CM nemůže smazat cizí task
      //   (vratná jistota — author sám se rozhodne).
      allow delete: if isTaskAuthor();

      // ------ Comments subcollection (V3) ------
      match /comments/{commentId} {
        // READ — V24: gated on parent task read access.
        //   Stejný read scope jako parent task (CM nesmí vidět komenty
        //   k tasku, který nevidí).
        allow read: if canReadTask(get(/databases/$(database)/documents/tasks/$(taskId)).data);

        // CREATE — author = self, body shape, plus parent task read access (V24).
        allow create: if isSignedIn()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.body is string
                      && canReadTask(get(/databases/$(database)/documents/tasks/$(taskId)).data);

        // UPDATE — author-only pro body/editedAt; reactions toggle pro kohokoli
        //   s parent task read access (V24).
        allow update: if isSignedIn()
                      && canReadTask(get(/databases/$(database)/documents/tasks/$(taskId)).data)
                      && (
                        // Author edit of body/editedAt
                        (resource.data.authorUid == request.auth.uid
                         && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['body', 'editedAt', 'reactions']))
                        // Or anyone toggling reactions only
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['reactions'])
                      );

        // DELETE — author only (s read access aby vůbec věděl o existenci).
        allow delete: if isSignedIn()
                      && resource.data.authorUid == request.auth.uid
                      && canReadTask(get(/databases/$(database)/documents/tasks/$(taskId)).data);
      }
    }

    // ------ Categories ------
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Locations (V7: user-managed, OWNER-only writes) ------
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Attachments (metadata legacy; binaries live in Firebase Storage) ------
    match /attachments/{attachmentId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner()
                            && request.resource.data.taskId is string;
      allow delete: if isOwner();
    }


    // ------ Document Types (V19: admin-managed taxonomy) ------
    match /documentTypes/{docTypeId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Phases (V23: configurable build phases) ------
    match /phases/{phaseId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Events (V18) ------
    // Calendar-aware eventy s fixním datetime. Paralelí s tasks rules
    // (V17.1 permissions model), jen bez sharedWithRoles / commentCount
    // side-effects.
    //
    // V24 — events nejsou role-restricted (CM smí vidět + tvořit), takže
    //   read zůstává otevřený pro všechny signed-in. authorRole snapshot
    //   přijímá nově i CONSTRUCTION_MANAGER.
    match /events/{eventId} {
      // READ — V15.2 styl: kdokoliv signed-in čte detail. Listing filtrujeme
      // klientsky (jsem invitee OR autor). Server-side filter by komplikoval
      // queries s composite indexy; user experience stejná — každý má jen
      // malou množinu events, důvěryhodní users.
      allow read: if isSignedIn();

      // CREATE — createdBy = self, title povinný, authorRole snapshot.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.authorRole in ['OWNER', 'PROJECT_MANAGER', 'CONSTRUCTION_MANAGER']
                    && request.resource.data.status in ['UPCOMING', 'AWAITING_CONFIRMATION', 'HAPPENED', 'CANCELLED']
                    && request.resource.data.inviteeUids is list
                    && request.resource.data.inviteeUids.size() >= 1;

      // UPDATE — V17.1 pattern + V24 rozšířené:
      //   - autor smí editovat vše
      //   - OWNER smí editovat OWNER-vytvořený event (cross-OWNER household)
      //   - CM smí editovat CM-vytvořený event (cross-CM tým, V24)
      //   - PM-created eventy smí jen autor-PM
      //   - scheduled CF (S09 AWAITING transition) používá Admin SDK, bypass
      allow update: if isTaskAuthor()
                    || isCrossOwnerEditable()
                    || isCrossCmEditable();

      // DELETE — pouze autor (i cross-OWNER / cross-CM respektuje).
      allow delete: if isTaskAuthor();

      // ------ RSVP subcollection (S05 chystá) ------
      // Placeholder: self-write, read kdokoliv. V S05 dopracujeme detail
      // schema + validaci.
      match /rsvps/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
