rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------ Helpers ------
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner() {
      return isSignedIn() && userRole() == 'OWNER';
    }

    function isProjectManager() {
      return isSignedIn() && userRole() == 'PROJECT_MANAGER';
    }

    // V5 — batch comment writes touch the parent task to bump commentCount / updatedAt
    // (and optionally status + assigneeUid when the comment carries a workflow action).
    // Any signed-in user must be able to make this side-effect update, otherwise e.g. PM
    // commenting on an OWNER-created task fails the whole batch. We gate by requiring
    // commentCount to be one of the affected keys — prevents this clause from being
    // abused to flip status/assignee without actually writing a comment.
    function isCommentSideEffect() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['commentCount', 'updatedAt', 'status', 'assigneeUid'])
             && request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['commentCount']);
    }

    // Task creator (V3 multi-author ready). Also covers legacy OWNER-created tasks.
    function isTaskAuthor() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // V17.1 — cross-OWNER edit: OWNER účet je sdílený prostor (typicky
    //   manžel + manželka). Co vytvořil jeden OWNER, může druhý editovat.
    //   PM-created tasky jsou soukromé (jen autor-PM).
    //
    //   Legacy tasky bez authorRole default na OWNER (historicky v drtivé
    //   většině, PM teprve nedávno dostal schopnost create).
    function isCrossOwnerEditable() {
      return isOwner() && (
        !('authorRole' in resource.data)
        || resource.data.authorRole == 'OWNER'
      );
    }

    // ------ Users ------
    // V3: any authenticated user can list users (for mention autocomplete + assignee dropdown).
    match /users/{uid} {
      allow read: if isSignedIn();

      // V16.1 — user may self-update notificationPrefs a displayName
      // ("Přezdívka"). Role + email zůstávají Admin-SDK only. Diff gate
      // odmítne i balíčkovaný patch, který by se snažil změnit cokoliv
      // jiného. Oba fieldy lze posílat zvlášť nebo společně.
      //
      // V18-S12 — přidány `calendarToken` a `calendarTokenRotatedAt`
      // (webcal subscription) + bookkeeping `updatedAt`. User si sám
      // lazy-generuje token při prvním otevření Kalendář sekce a dělá
      // reset přes stejné diff-gate. Server-side (CF, admin) pořád
      // může psát pomocí Admin SDK bez těchto rules.
      allow update: if isSignedIn()
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly([
                         'notificationPrefs',
                         'displayName',
                         'contactEmail',
                         'calendarToken',
                         'calendarTokenRotatedAt',
                         'calendarLastFetchedAt',
                         'onboardingCompletedAt',
                         'updatedAt',
                       ]);

      // Create / delete via Admin SDK only.
      allow create, delete: if false;

      // ------ Devices (FCM registrations, V15) ------
      // Each user owns their own devices subcollection. Nobody else can
      // read or write — tokens are effectively credentials for push
      // delivery, they don't leave the owning account.
      match /devices/{deviceId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // ------ Notifications inbox (V15.1) ------
      // Mirror of push notifications, persisted for in-app feed. Server
      // (Cloud Function) writes; owner reads + marks-read. Owner can't
      // delete (keeps a consistent audit trail); retention lives in a
      // scheduled cleanup function.
      match /notifications/{notifId} {
        allow read: if isSignedIn() && request.auth.uid == uid;
        // Owner may only patch readAt to set it from null → timestamp.
        // No other field can be modified from the client — content is
        // written server-side.
        allow update: if isSignedIn()
                      && request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['readAt']);
        // Create + delete via Admin SDK only (Cloud Function).
        allow create, delete: if false;
      }
    }

    // ------ Tasks ------
    match /tasks/{taskId} {
      // READ — V15.2:
      //   Any signed-in user can read any task (list or single get). The
      //   workspace is one household + its PM; there are no task-level secrets
      //   to keep between them. Role distinction lives at the write/edit level
      //   (see UPDATE below) and in the UI (PM gets a read-only view of napady
      //   that haven't been explicitly shared). Deep-linking from a push
      //   notification needs this — without it PM click-throughs on unshared
      //   napady bounced to NotFound via the rules 403.
      allow read: if isSignedIn();

      // CREATE — createdBy musí být self, sensible type + status, a V17.1
      //   snapshot authorRole. Legacy migrace přijme i záznamy bez pole,
      //   ale nové writes je musí obsahovat.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.type in ['napad', 'otazka', 'ukol']
                    && request.resource.data.status is string
                    && request.resource.data.authorRole in ['OWNER', 'PROJECT_MANAGER'];

      // UPDATE — V17.1 model:
      //   - Autor tasku může editovat vše.
      //   - OWNER může editovat jakýkoliv OWNER-vytvořený task (cross-OWNER
      //     shared workspace — manželé sdílí).
      //   - Jakýkoliv signed-in může aplikovat comment-side-effect diff aby
      //     batch writes z createComment prošly bez ohledu na autora tasku.
      //   - PM-vytvořený task smí editovat jen autor-PM (žádná cross-PM
      //     sharing; PM je jednotlivec, ne sdílený účet).
      allow update: if isTaskAuthor()
                    || isCrossOwnerEditable()
                    || (isSignedIn() && isCommentSideEffect());

      // DELETE — pouze autor. Cross-OWNER nemůže smazat cizí task (vratná
      //   jistota — author sám se rozhodne).
      allow delete: if isTaskAuthor();

      // ------ Comments subcollection (V3) ------
      match /comments/{commentId} {
        // READ — any authenticated user (parallel to tasks read).
        allow read: if isSignedIn();

        // CREATE — author must be self; enforce required fields shape.
        allow create: if isSignedIn()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.body is string;

        // UPDATE — author-only, can only change body, editedAt, reactions.
        //         (Reactions are also toggleable by non-authors; rule split below.)
        allow update: if isSignedIn()
                      && (
                        // Author edit of body/editedAt
                        (resource.data.authorUid == request.auth.uid
                         && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['body', 'editedAt', 'reactions']))
                        // Or anyone toggling reactions only
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['reactions'])
                      );

        // DELETE — author only.
        allow delete: if isSignedIn()
                      && resource.data.authorUid == request.auth.uid;
      }
    }

    // ------ Categories ------
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Locations (V7: user-managed, OWNER-only writes) ------
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Attachments (metadata legacy; binaries live in Firebase Storage) ------
    match /attachments/{attachmentId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner()
                            && request.resource.data.taskId is string;
      allow delete: if isOwner();
    }

    // ------ Events (V18) ------
    // Calendar-aware eventy s fixním datetime. Paralelí s tasks rules
    // (V17.1 permissions model), jen bez sharedWithPm / commentCount
    // side-effects.
    match /events/{eventId} {
      // READ — V15.2 styl: kdokoliv signed-in čte detail. Listing filtrujeme
      // klientsky (jsem invitee OR autor). Server-side filter by komplikoval
      // queries s composite indexy; user experience stejná — každý má jen
      // malou množinu events, důvěryhodní users.
      allow read: if isSignedIn();

      // CREATE — createdBy = self, title povinný, authorRole snapshot.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.authorRole in ['OWNER', 'PROJECT_MANAGER']
                    && request.resource.data.status in ['UPCOMING', 'AWAITING_CONFIRMATION', 'HAPPENED', 'CANCELLED']
                    && request.resource.data.inviteeUids is list
                    && request.resource.data.inviteeUids.size() >= 1;

      // UPDATE — V17.1 pattern:
      //   - autor smí editovat vše
      //   - OWNER smí editovat OWNER-vytvořený event (cross-OWNER household)
      //   - PM-created eventy smí jen autor-PM
      //   - scheduled CF (S09 AWAITING transition) používá Admin SDK, bypass
      allow update: if isTaskAuthor()
                    || isCrossOwnerEditable();

      // DELETE — pouze autor (i cross-OWNER respektuje).
      allow delete: if isTaskAuthor();

      // ------ RSVP subcollection (S05 chystá) ------
      // Placeholder: self-write, read kdokoliv. V S05 dopracujeme detail
      // schema + validaci.
      match /rsvps/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
