# Loaded automatically by Vite/Vitest when MODE === "test" (i.e. during
# `vitest run` and `npm test`). NOT loaded by `npm run build` or dev.
#
# Tests mock @/lib/firebase via vi.mock(...), so no real SDK call ever
# happens with these values. They exist purely to satisfy firebase.ts'
# boot-time "Missing Firebase config" throw.
#
# Safe to commit — none of these are real credentials.

VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=test-project
VITE_FIREBASE_STORAGE_BUCKET=test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=0
VITE_FIREBASE_APP_ID=1:0:web:0
