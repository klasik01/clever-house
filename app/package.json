{
  "name": "chytry-dum-na-vsi",
  "private": true,
  "version": "1.19.0",
  "engines": {
    "node": ">=24.15.0 <26"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "postbuild": "cp dist/index.html dist/404.html",
    "build:pages": "VITE_BASE_PATH=/clever-house/ npm run build",
    "emulators": "firebase emulators:start --only firestore,auth,functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm test && npm run functions:test",
    "test:coverage:all": "npm run test:coverage && npm run functions:test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:permissions": "node scripts/gen-permissions-md.mjs",
    "gen:ics": "vite-node scripts/gen-sample-ics.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck && npm run functions:typecheck",
    "functions:install": "npm --prefix functions install",
    "functions:build": "npm --prefix functions run build",
    "functions:typecheck": "npm --prefix functions run typecheck",
    "functions:test": "npm --prefix functions run test",
    "functions:test:watch": "npm --prefix functions run test:watch",
    "functions:test:coverage": "npm --prefix functions run test:coverage",
    "functions:logs": "npm --prefix functions run logs",
    "functions:serve": "npm --prefix functions run serve",
    "functions:shell": "npm --prefix functions run shell",
    "deploy:install": "npm --prefix deploy install",
    "deploy:dev:dry": "npm --prefix deploy run deploy:dev:dry",
    "deploy:dev": "npm --prefix deploy run deploy:dev",
    "deploy:ope:dry": "npm --prefix deploy run deploy:ope:dry",
    "deploy:ope": "npm --prefix deploy run deploy:ope",
    "rules:deploy:dev": "npm --prefix deploy run rules:deploy:dev",
    "rules:deploy:ope": "npm --prefix deploy run rules:deploy:ope",
    "storage:deploy:dev": "npm --prefix deploy run storage:deploy:dev",
    "storage:deploy:ope": "npm --prefix deploy run storage:deploy:ope",
    "deploy:functions:dev": "npm --prefix deploy run functions:deploy:dev",
    "deploy:functions:ope": "npm --prefix deploy run functions:deploy:ope",
    "firebase": "firebase",
    "install:all": "npm install && npm run functions:install && npm run deploy:install"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.18",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/pm": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "browser-image-compression": "^2.0.2",
    "firebase": "^10.12.5",
    "lucide-react": "^0.383.0",
    "pdfmake": "^0.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.28.0",
    "tiptap-markdown": "^0.8.10"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "@types/pdfmake": "^0.2.9",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.1.8",
    "jsdom": "^25.0.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/jest-dom": "^6.6.3",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "firebase-tools": "^13.29.0",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "overrides": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
