{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "*.log",
        "src",
        "tsconfig.json"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "emulators": {
    "firestore": { "port": 8080 },
    "auth":      { "port": 9099 },
    "storage":   { "port": 9199 },
    "functions": { "port": 5001 },
    "ui":        { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
