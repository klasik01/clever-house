rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------ Helpers ------
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOwner() {
      return isSignedIn() && userRole() == 'OWNER';
    }

    function isProjectManager() {
      return isSignedIn() && userRole() == 'PROJECT_MANAGER';
    }

    // PM-allowed update fields on tasks: keeps the V2 "Potrebuji doplnit" flow working.
    function pmAllowedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['projektantAnswer', 'projektantAnswerAt', 'status', 'assigneeUid', 'updatedAt']);
    }

    // V5 — batch comment writes touch the parent task to bump commentCount / updatedAt
    // (and optionally status + assigneeUid when the comment carries a workflow action).
    // Any signed-in user must be able to make this side-effect update, otherwise e.g. PM
    // commenting on an OWNER-created task fails the whole batch. We gate by requiring
    // commentCount to be one of the affected keys — prevents this clause from being
    // abused to flip status/assignee without actually writing a comment.
    function isCommentSideEffect() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['commentCount', 'updatedAt', 'status', 'assigneeUid'])
             && request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['commentCount']);
    }

    // Task creator (V3 multi-author ready). Also covers legacy OWNER-created tasks.
    function isTaskAuthor() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // ------ Users ------
    // V3: any authenticated user can list users (for mention autocomplete + assignee dropdown).
    match /users/{uid} {
      allow read: if isSignedIn();
      // Write via Firebase Admin SDK (manual setup), not from client.
      allow write: if false;
    }

    // ------ Tasks ------
    match /tasks/{taskId} {
      // READ — V3-polish:
      //   list: any signed-in user can list; client-side filters napady by sharedWithPm.
      //   get:  per-document enforcement (direct /t/:id fetches gated here).
      allow list: if isSignedIn();
      // V10: every OWNER sees every OWNER's napady (workspace = one household).
      //      Otazky are shared across the whole workspace. Napady shared with PM
      //      stay visible to PM regardless of OWNER role.
      allow get:  if isSignedIn() && (
        resource.data.createdBy == request.auth.uid
        || resource.data.type == 'otazka'
        || (resource.data.type == 'napad' && isOwner())
        || (resource.data.type == 'napad' && resource.data.sharedWithPm == true)
      );

      // CREATE — must set createdBy to self, sensible type + status.
      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.type in ['napad', 'otazka']
                    && request.resource.data.status is string;

      // UPDATE — author can edit anything; PM can flip legacy V2 fields;
      // any signed-in user can apply the comment-side-effect diff so batch writes
      // from createComment succeed regardless of who authored the task.
      allow update: if isTaskAuthor()
                    || (isProjectManager()
                        && resource.data.type == 'otazka'
                        && pmAllowedFields())
                    || (isSignedIn() && isCommentSideEffect());

      // DELETE — only author.
      allow delete: if isTaskAuthor();

      // ------ Comments subcollection (V3) ------
      match /comments/{commentId} {
        // READ — any authenticated user (parallel to tasks read).
        allow read: if isSignedIn();

        // CREATE — author must be self; enforce required fields shape.
        allow create: if isSignedIn()
                      && request.resource.data.authorUid == request.auth.uid
                      && request.resource.data.body is string;

        // UPDATE — author-only, can only change body, editedAt, reactions.
        //         (Reactions are also toggleable by non-authors; rule split below.)
        allow update: if isSignedIn()
                      && (
                        // Author edit of body/editedAt
                        (resource.data.authorUid == request.auth.uid
                         && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['body', 'editedAt', 'reactions']))
                        // Or anyone toggling reactions only
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['reactions'])
                      );

        // DELETE — author only.
        allow delete: if isSignedIn()
                      && resource.data.authorUid == request.auth.uid;
      }
    }

    // ------ Categories ------
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Locations (V7: user-managed, OWNER-only writes) ------
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isOwner();
    }

    // ------ Attachments (metadata legacy; binaries live in Firebase Storage) ------
    match /attachments/{attachmentId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner()
                            && request.resource.data.taskId is string;
      allow delete: if isOwner();
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
